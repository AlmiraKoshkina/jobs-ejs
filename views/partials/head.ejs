<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Learning Tracker</title>

    <style>
      body {
        font-family: Arial, sans-serif;
        margin: 40px;
        background: #f5f5f5;
      }

      h1,
      h2 {
        color: #333;
      }

      table {
        border-collapse: collapse;
        width: 100%;
        background: white;
      }

      th,
      td {
        padding: 10px;
        border: 1px solid #ddd;
        text-align: left;
      }

      th {
        background: #f0f0f0;
      }

      button {
        padding: 6px 12px;
        border: none;
        background: #0077ff;
        color: white;
        cursor: pointer;
        border-radius: 4px;
      }

      button:hover {
        background: #005ed6;
      }

      a {
        text-decoration: none;
      }

      .progress.planned {
        color: gray;
        font-weight: bold;
      }

      .progress.in-progress {
        color: orange;
        font-weight: bold;
      }

      .progress.completed {
        color: green;
        font-weight: bold;
      }
    </style>
  </head>
  <body></body>
</html>
